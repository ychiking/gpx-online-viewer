{
  "name": "YCHiking GPX 檢視器",
  "short_name": "YCHiking",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#f6f6f6",
  "icons": [
    {
      "src": "https://ychiking.github.io/gpx-online-viewer/webicon.png",
      "sizes": "192x192",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "/receive-gpx",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "gpx_file",
          "accept": [".gpx", "application/gpx+xml"]
        }
      ]
    }
  }
}
